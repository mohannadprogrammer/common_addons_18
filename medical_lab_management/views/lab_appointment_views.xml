<?xml version="1.0" encoding="UTF-8"?>
<odoo>
 <!--        Creating lab patient view-->
    
    <!-- ============================================================
         Lab Invoice action
    ============================================================ -->
    <record id="lab_invoice_action" model="ir.actions.act_window">
        <field name="name">Lab Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form,kanban,graph,pivot</field>
        <field name="view_id" ref="account.view_move_tree"/>
        <field name="domain">[('is_lab_invoice', '=', True)]</field>
        <field name="search_view_id" ref="account.view_account_invoice_filter"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No lab invoices yet.</p>
        </field>
    </record>

    <!-- ============================================================
         KANBAN view
    ============================================================ -->
    <record id="kanban_view_lab_appointment" model="ir.ui.view">
        <field name="name">lab.appointment.kanban</field>
        <field name="model">lab.appointment</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="state"/>
                <field name="patient_id"/>
                <field name="name"/>
                <field name="appointment_date"/>
                <field name="amount_total"/>
                <field name="priority"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="patient_id"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="name"/>
                                    </small>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <ul class="list-unstyled mb-0">
                                    <li>
                                        <i class="fa fa-calendar "/>
                                        <field name="appointment_date" widget="date"/>
                                    </li>
                                    <li>
                                        <i class="fa fa-money"/>
                                        Total: <field name="amount_total"/>
                                    </li>
                                </ul>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="state"  widget="badge" 
                       
                       />
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         LIST view
    ============================================================ -->
    <record id="lab_appointment_view_list" model="ir.ui.view">
        <field name="name">lab.appointment.view.list</field>
        <field name="model">lab.appointment</field>
        <field name="arch" type="xml">
            <list string="Lab Orders" 
            >
                <field name="name"/>
                <field name="patient_id"/>
                <field name="appointment_date"/>
                <field name="physician_id" />
                <field name="amount_total" string="Total"/>
                <field name="priority"/>
                <field name="state" 
                     widget="label_selection"
                                options="{'classes': {'draft': 'info', 'to_invoice' :'info', 'invoiced' :'success','request_lab' :'warning' ,  'cancel': 'danger', 'completed': 'success'}}" class="ms-auto"
                />
            </list>
        </field>
    </record>

    <!-- ============================================================
         FORM view
    ============================================================ -->
    <record id="lab_appointment_view_form" model="ir.ui.view">
        <field name="name">lab.appointment.view.form</field>
        <field name="model">lab.appointment</field>
        <field name="arch" type="xml">
            <form string="Lab Order">

                <header>
                    <!-- Step 1: Confirm (Draft only) -->
                    <button name="action_confirm_order"
                            string="Confirm Order"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <!-- Step 2: Create Invoice (To Invoice only) -->
                    <button name="action_create_invoice"
                            string="Create Invoice"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'to_invoice'"/>

                    <!-- Step 3a: Open payment wizard on the invoice -->
                    <button name="action_register_payment"
                            string="Register Payment"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'invoiced'"/>

                    <!-- Step 3b: Mark order as Paid after payment registered -->
                    <button name="action_check_payment_and_unlock"
                            string="Confirm Payment Received"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'invoiced'"
                            confirm="This will mark the order as Paid and allow lab tests to start. Confirm only after payment is fully received."/>

                    <!-- Step 4: Start lab (Paid only) -->
                    <button name="action_request_lab"
                            string="Start Lab Tests"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'paid'"/>

                    <!-- Step 5: Results ready (Lab in progress only) -->
                    <button name="action_mark_completed"
                            string="Mark Results Ready"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'request_lab'"/>

                    <!-- Cancel -->
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('draft','to_invoice')"
                            confirm="Are you sure you want to cancel this lab order?"/>

                    <!-- Reset to Draft -->
                    <button name="action_set_to_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancel'"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,to_invoice,invoiced,paid,request_lab,completed"/>
                </header>

                <sheet>
                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                invisible="inv_count == 0">
                            <field name="inv_count" widget="statinfo"
                                   string="Invoices"/>
                        </button>
                        <button name="action_view_lab_requests"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-flask"
                                invisible="request_count == 0">
                            <field name="request_count" widget="statinfo"
                                   string="Lab Requests"/>
                        </button>
                    </div>

                    <!-- Order title -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Main fields -->
                    <group>
                        <group string="Patient Information">
                            <field name="patient_id"
                                   readonly="state != 'draft'"/>
                            <field name="physician_id"
                                   domain="[('is_physician','=',True)]"
                                   />
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Order Details">
                            <field name="date" readonly="1"/>
                            <field name="appointment_date"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- Payment pending notice -->
                    <div class="alert alert-warning mb-0"
                         invisible="state != 'invoiced'">
                        <p>
                            <strong>Awaiting Payment</strong> —
                            Lab tests cannot start until the invoice is fully paid.
                            Click <strong>Register Payment</strong> on the invoice,
                            then use <strong>Confirm Payment Received</strong> above.
                        </p>
                    </div>

                    <!-- Order lines -->
                    <notebook colspan="4">
                        <page string="Lab Tests" name="order_lines">
                            <field name="appointment_line_ids"
                                   readonly="state not in ('draft', 'to_invoice')">
                                <list string="Lab Tests" editable="bottom">
                                    <field name="lab_test_id"/>
                                    <field name="cost" string="Unit Price"/>
                                    <!-- <field name="price_subtotal"
                                           string="Subtotal"
                                           readonly="1"/> -->
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right"
                                   colspan="2" name="order_total">
                                <field name="amount_untaxed"
                                       readonly="1"
                                       string="Subtotal"/>
                                <field name="amount_total"
                                       class="oe_subtotal_footer_separator"
                                       readonly="1"
                                       string="Total"/>
                            </group>
                            <div class="clearfix"/>
                        </page>

                        <page string="Notes" name="notes">
                            <field name="comment"
                                   placeholder="Internal notes, clinical instructions…"/>
                        </page>
                    </notebook>

                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
         SEARCH view
    ============================================================ -->
    <record id="lab_appointment_view_search" model="ir.ui.view">
        <field name="name">lab.appointment.view.search</field>
        <field name="model">lab.appointment</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Lab Orders">
                <field name="name" string="Order Reference"/>
                <field name="patient_id"/>
                <field name="physician_id"/>
                <field name="appointment_date"/>
                <separator/>
                <filter name="filter_draft"
                        string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="filter_to_invoice"
                        string="To Invoice"
                        domain="[('state','=','to_invoice')]"/>
                <filter name="filter_invoiced"
                        string="Awaiting Payment"
                        domain="[('state','=','invoiced')]"/>
                <filter name="filter_paid"
                        string="Paid"
                        domain="[('state','=','paid')]"/>
                <filter name="filter_in_progress"
                        string="Lab In Progress"
                        domain="[('state','=','request_lab')]"/>
                <filter name="filter_completed"
                        string="Results Ready"
                        domain="[('state','=','completed')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_patient"
                            string="Patient"
                            context="{'group_by':'patient_id'}"/>
                    <filter name="group_state"
                            string="Status"
                            context="{'group_by':'state'}"/>
                    <filter name="group_date"
                            string="Scheduled Date"
                            context="{'group_by':'appointment_date:week'}"/>
                    <filter name="group_physician"
                            string="Physician"
                            context="{'group_by':'physician_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         Window actions
    ============================================================ -->
    <record id="act_open_lab_appointment_view" model="ir.actions.act_window">
        <field name="name">Lab Orders</field>
        <field name="res_model">lab.appointment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="lab_appointment_view_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Lab Order.
            </p>
        </field>
    </record>

    <record id="lab_appointment_action" model="ir.actions.act_window">
        <field name="name">Today's Lab Orders</field>
        <field name="res_model">lab.appointment</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="lab_appointment_view_search"/>
        <field name="domain">[
            ('appointment_date', '&gt;=', ((datetime.date.today() - datetime.timedelta(days=0)).strftime('%Y-%m-%d 00:00:00'))),
            ('appointment_date', '&lt;=', ((datetime.date.today() - datetime.timedelta(days=0)).strftime('%Y-%m-%d 23:59:59')))
        ]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No lab orders scheduled for today.</p>
        </field>
    </record>

    <!-- ============================================================
         Menu items
    ============================================================ -->
    <menuitem id="lab_patient_menu_root" name="Laboratory" sequence="40"
              groups="group_lab_management_user,group_lab_management_technician"
              web_icon="medical_lab_management,static/description/icon.png"/>


    <menuitem id="menu_lab_appointment"
              name="Lab Orders"
              sequence="11"
              parent="lab_patient_menu_root"
              groups="group_lab_management_user,group_lab_management_technician"/>

    <menuitem id="menu_lab_appointment_child"
              name="All Orders"
              sequence="10"
              parent="menu_lab_appointment"
              action="act_open_lab_appointment_view"
              groups="group_lab_management_user,group_lab_management_technician"/>

    <menuitem id="menu_lab_appointment_child_2"
              name="Today's Orders"
              sequence="11"
              parent="menu_lab_appointment"
              action="lab_appointment_action"
              groups="group_lab_management_user,group_lab_management_technician"/>

</odoo>