<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_stock_valuation" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.stock.valuation</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="Automated Stock Valuation" name="stock_valuation_setting_container">

                    <!-- Master on/off toggle -->
                    <setting
                        string="Automated Stock Valuation Engine"
                        help="Automatically create stock valuation journal entries for
                              purchases, sales, manufacturing and inventory adjustments.
                              Disable to stop all custom valuation posting for this company.">
                        <field name="custom_stock_valuation_enabled"/>
                    </setting>

                    <!--
                        Odoo 17-19: use `invisible` directly on the element, not attrs.
                        The expression is a domain string evaluated against the view record.
                    -->
                    <setting
                        string="Stock Valuation Account"
                        help="Asset account representing real-time stock value (DR on receipt)."
                        invisible="not custom_stock_valuation_enabled">
                        <field name="property_stock_valuation_account_id"/>
                    </setting>
                    <setting
                        string="Stock Input / GR-IR"
                        help="Clearing liability credited on purchase receipt, debited on vendor bill."
                        invisible="not custom_stock_valuation_enabled">
                        <field name="property_stock_input_account_id"/>
                    </setting>
                    <setting
                        string="Stock Output (Interim)"
                        help="Clearing asset debited on delivery, credited when COGS is recognised."
                        invisible="not custom_stock_valuation_enabled">
                        <field name="property_stock_output_account_id"/>
                    </setting>
                    <setting
                        string="Cost of Goods Sold"
                        help="Expense account debited when a customer invoice is validated."
                        invisible="not custom_stock_valuation_enabled">
                        <field name="property_account_expense_categ_id"/>
                    </setting>
                    <setting
                        string="Production / WIP Account"
                        help="WIP asset debited on raw-material consumption, credited on finished-good receipt."
                        invisible="not custom_stock_valuation_enabled">
                        <field name="property_production_account_id"/>
                    </setting>
                    <setting
                        string="Inventory Loss Account"
                        help="Expense account for shrinkage and inventory adjustments."
                        invisible="not custom_stock_valuation_enabled">
                        <field name="property_inventory_loss_account_id"/>
                    </setting>

                </block>
            </xpath>
        </field>
    </record>
</odoo>
