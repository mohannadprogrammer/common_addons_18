<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_category_form_view_inherit_stock_valuation" model="ir.ui.view">
        <field name="name">product.category.form.inherit.stock.valuation</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <!--
                    The group and every field inside it are hidden when the
                    Automated Stock Valuation Engine is disabled for the company.
                    Odoo 17-19 syntax: `invisible` attribute with a Python expression.
                    `custom_stock_valuation_enabled` is a computed Boolean on
                    product.category that mirrors env.company.custom_stock_valuation_enabled.
                -->
                <group
                    string="Inventory Valuation Accounts"
                    name="stock_valuation_accounts"
                    col="2"
                    colspan="2"
                    invisible="not custom_stock_valuation_enabled">
                    <field name="custom_stock_valuation_enabled" invisible="1"/>
                    <field name="property_stock_valuation_account_id"/>
                    <field name="property_stock_input_account_id"/>
                    <field name="property_stock_output_account_id"/>
                    <field name="property_account_expense_categ_id"/>
                    <field name="property_production_account_id"/>
                    <field name="property_inventory_loss_account_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
