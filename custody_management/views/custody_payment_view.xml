<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custody_payment_form" model="ir.ui.view">
        <field name="name">custody.payment.form</field>
        <field name="model">custody.payment</field>
        <field name="arch" type="xml">
            <form string="Payment">
                <header>
                    <button name="action_post" string="Post" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="custody_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="payment_type"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount" widget="monetary"/>
                            <field name="journal_id" options="{'no_create': True}"/>
                            <field name="payment_method_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Accounting">
                        <field name="account_move_id" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_custody_payment_tree" model="ir.ui.view">
        <field name="name">custody.payment.tree</field>
        <field name="model">custody.payment</field>
        <field name="arch" type="xml">
            <list string="Payments">
                <field name="name"/>
                <field name="custody_id"/>
                <field name="payment_type"/>
                <field name="journal_id"/>
                <field name="date"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_custody_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">custody.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Custody Payment Wizard View -->
    <record id="view_custody_payment_wizard_form" model="ir.ui.view">
        <field name="name">custody.payment.wizard.form</field>
        <field name="model">custody.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Disburse Custody">
                <sheet>
                    <group>
                        <group>
                            <field name="custody_id" readonly="1"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount" widget="monetary"/>
                            <field name="journal_id" options="{'no_create': True}"/>
                            <field name="payment_method_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_pay" string="Confirm Payment" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
