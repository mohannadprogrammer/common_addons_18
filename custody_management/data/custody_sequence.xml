<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_custody_custody" model="ir.sequence">
            <field name="name">Custody Number</field>
            <field name="code">custody.custody</field>
            <field name="prefix">CST/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_custody_settlement" model="ir.sequence">
            <field name="name">Settlement Number</field>
            <field name="code">custody.settlement</field>
            <field name="prefix">STL/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_custody_payment" model="ir.sequence">
            <field name="name">Payment Reference</field>
            <field name="code">custody.payment</field>
            <field name="prefix">PAY/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
