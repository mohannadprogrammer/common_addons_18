<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Application Category -->
    <record id="module_category_custody_management" model="ir.module.category">
        <field name="name">Custody </field>
        <field name="description">Custody Management</field>
        <field name="sequence">10</field>
    </record>

    <!-- Security Groups -->
    <record id="group_custody_employee" model="res.groups">
        <field name="name">Employee</field>
        <field name="category_id" ref="module_category_custody_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_custody_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_custody_management"/>
        <field name="implied_ids" eval="[(4, ref('group_custody_employee'))]"/>
    </record>

    <record id="group_custody_finance" model="res.groups">
        <field name="name">Finance</field>
        <field name="category_id" ref="module_category_custody_management"/>
        <field name="implied_ids" eval="[(4, ref('group_custody_manager'))]"/>
    </record>

    <record id="group_custody_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_custody_management"/>
        <field name="implied_ids" eval="[(4, ref('group_custody_finance'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="custody_custody_rule_employee" model="ir.rule">
        <field name="name">Custody: Employee sees own company records</field>
        <field name="model_id" ref="model_custody_custody"/>
        <field name="groups" eval="[(4, ref('group_custody_employee'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id), ('company_id', 'in', company_ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="custody_custody_rule_manager" model="ir.rule">
        <field name="name">Custody: Manager sees department records</field>
        <field name="model_id" ref="model_custody_custody"/>
        <field name="groups" eval="[(4, ref('group_custody_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="custody_custody_rule_finance" model="ir.rule">
        <field name="name">Custody: Finance sees all company records</field>
        <field name="model_id" ref="model_custody_custody"/>
        <field name="groups" eval="[(4, ref('group_custody_finance'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="custody_settlement_rule" model="ir.rule">
        <field name="name">Custody Settlement: Multi-Company</field>
        <field name="model_id" ref="model_custody_settlement"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="custody_payment_rule" model="ir.rule">
        <field name="name">Custody Payment: Multi-Company</field>
        <field name="model_id" ref="model_custody_payment"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
