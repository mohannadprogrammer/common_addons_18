<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custody_cancel_wizard_form" model="ir.ui.view">
        <field name="name">custody.cancel.wizard.form</field>
        <field name="model">custody.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel Custody">
                <sheet>
                    <group>
                        <field name="custody_id" readonly="1"/>
                        <field name="reason" placeholder="Enter cancellation reason..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_cancel" string="Confirm Cancellation" type="object" class="btn-danger"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
