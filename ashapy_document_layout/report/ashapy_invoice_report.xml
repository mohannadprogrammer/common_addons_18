<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="ashapy_report_invoice_document" inherit_id="account.report_invoice_document">

            <xpath expr="//t[@t-if='o.partner_shipping_id and (o.partner_shipping_id != o.partner_id)']" position="replace">
                <div class="row" style="margin-bottom: 12px;">
                    <div class="col-6">
                        <strong>المحترم / الأخ</strong><br/>
                        <span t-field="o.partner_id.name"/>
                    </div>
                    <div class="col-6" style="text-align: right;">
                        <strong>البيان :</strong>
                    </div>
                </div>
            </xpath>

            <xpath expr="//t[@t-elif='o.partner_shipping_id and (o.partner_shipping_id == o.partner_id)']" position="replace">
                <div class="row" style="margin-bottom: 12px;">
                    <div class="col-6">
                        <strong>المحترم / الأخ</strong><br/>
                        <span t-field="o.partner_id.name"/>
                    </div>
                    <div class="col-6" style="text-align: right;">
                        <strong>البيان :</strong>
                    </div>
                </div>
            </xpath>

            <xpath expr="//t[@t-else='']" position="replace">
                <div class="row" style="margin-bottom: 12px;">
                    <div class="col-6">
                        <strong>المحترم / الأخ</strong><br/>
                        <span t-field="o.partner_id.name"/>
                    </div>
                    <div class="col-6" style="text-align: right;">
                        <strong>البيان :</strong>
                    </div>
                </div>
            </xpath>

            <xpath expr="//div[@id='informations']" position="replace"/>

            <xpath expr="//table[@name='invoice_line_table']" position="replace">
                <table class="table table-sm" style="width: 100%; table-layout: fixed; border-collapse: collapse; margin-bottom: 10px;">
                    <thead>
                        <tr style="border-top: 1px solid #000; border-bottom: 1px solid #000;">
                            <th style="width: 40%; text-align: left; padding: 4px; font-size: 11px;">الصنف</th>
                            <th style="width: 15%; text-align: center; padding: 4px; font-size: 11px;">الوحدة</th>
                            <th style="width: 15%; text-align: center; padding: 4px; font-size: 11px;">الكمية</th>
                            <th style="width: 15%; text-align: center; padding: 4px; font-size: 11px;">السعر</th>
                            <th style="width: 15%; text-align: center; padding: 4px; font-size: 11px;">الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <tr>
                                <td style="text-align: left; padding: 2px; font-size: 10px; overflow-wrap: break-word; word-wrap: break-word;"><span t-field="line.name"/></td>
                                <td style="text-align: center; padding: 2px; font-size: 10px;">
                                    <span t-field="line.product_uom_id"/>
                                </td>
                                <td style="text-align: center; padding: 2px; font-size: 10px;">
                                    <span t-field="line.quantity"/>
                                </td>
                                <td style="text-align: center; padding: 2px; font-size: 10px;">
                                    <span t-field="line.price_unit"/>
                                </td>
                                <td style="text-align: center; padding: 2px; font-size: 10px;">
                                    <span t-field="line.price_subtotal"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </xpath>

            <xpath expr="//div[@id='right-elements']" position="replace">
                <div style="margin-bottom: 10px;">
                    <table style="width: 50%; margin-left: auto; border: none;">
                        <tr>
                            <td style="text-align: left; font-size: 12px; font-weight: bold;">الكمية</td>
                            <td style="text-align: right; font-size: 12px;">
                                <span t-esc="sum(o.invoice_line_ids.mapped('quantity'))"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="text-align: left; font-size: 12px; font-weight: bold;">الإجمالي</td>
                            <td style="text-align: right; font-size: 12px;">
                                <span class="text-nowrap" t-field="o.amount_total"/>
                            </td>
                        </tr>
                    </table>
                </div>
                <div style="text-align: center; font-size: 10px; margin-bottom: 4px;">
                    الأسعار داخل الفاتوره تسري لي مدة 24 ساعه
                </div>
                <div style="text-align: center; font-size: 10px;">
                    الدعم الفني : 0122666710
                </div>
            </xpath>

            <xpath expr="//div[@id='payment_term']" position="replace">
                <div style="text-align: center; font-size: 10px; margin-top: 10px; border-top: 1px solid #000; padding-top: 8px;">
                    <div>FOR SOLAR ENERGY SYST</div>
                </div>
            </xpath>
        </template>
    </data>
</odoo>
