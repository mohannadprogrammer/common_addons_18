<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_close_shift_wizard_form" model="ir.ui.view">
        <field name="name">close.shift.wizard.form</field>
        <field name="model">close.shift.wizard</field>
        <field name="arch" type="xml">
            <form string="Close Shift">
                <sheet>
                    <group>
                        <field name="shift_id" invisible="1"/>
                        <field name="shift_name"/>
                        <field name="total_revenue"/>
                        <field name="total_doctor_billing"/>
                    </group>
                    <group string="Doctor Billing">
                        <field name="billing_line_ids">
                            <list>
                                <field name="doctor_id"/>
                                <field name="amount" widget="monetary"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm Close Shift" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_close_shift_wizard" model="ir.actions.act_window">
        <field name="name">Close Shift</field>
        <field name="res_model">close.shift.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
