<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_receipt" model="report.paperformat">
        <field name="name">Receipt (80mm)</field>
        <field name="format">custom</field>
        <field name="page_width">80</field>
        <field name="page_height">297</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <template id="receipt_invoice">
        <t t-call="web.html_container">
            <style>
                .container { padding: 0 2px !important; max-width: 74mm !important; }
                table { border-collapse: collapse; width: 100%; }
                td { vertical-align: top; }
            </style>
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang or o.company_id.partner_id.lang"/>
                <t t-call="clinic_management_system.receipt_invoice_document" t-lang="lang"/>
            </t>
        </t>
    </template>

    <template id="receipt_invoice_document">
        <div style="width: 74mm; font-family: 'DejaVu Sans Mono', 'Courier New', monospace; font-size: 7px; line-height: 1.3;">
            <t t-set="fmt" t-value="formatted[o.id]"/>

            <div style="text-align: center; margin-bottom: 3px;">
                <div style="font-size: 10px; font-weight: bold;">
                    <span t-field="o.company_id.name"/>
                </div>
                <div t-if="o.company_id.street" style="font-size: 6px;">
                    <span t-field="o.company_id.street"/>
                </div>
                <div t-if="o.company_id.phone" style="font-size: 6px;">
                    Tel: <span t-field="o.company_id.phone"/>
                </div>
            </div>

            <div style="text-align: center; border-top: 1px dashed #000; border-bottom: 1px dashed #000; padding: 1px 0; margin-bottom: 3px;">
                <strong style="font-size: 9px;">RECEIPT</strong>
            </div>

            <table style="font-size: 7px; margin-bottom: 3px;">
                <tr>
                    <td style="width: 25mm;">Receipt No:</td>
                    <td><strong><span t-field="o.name"/></strong></td>
                </tr>
                <tr>
                    <td>Date:</td>
                    <td><span t-field="o.invoice_date"/></td>
                </tr>
                <tr t-if="o.state == 'posted'">
                    <td>Status:</td>
                    <td>
                        <t t-if="o.payment_state == 'paid'"><strong style="color: #2e7d32;">PAID</strong></t>
                        <t t-elif="o.payment_state == 'partial'"><strong style="color: #e65100;">PARTIAL</strong></t>
                        <t t-elif="o.payment_state == 'not_paid'"><strong style="color: #c62828;">UNPAID</strong></t>
                        <t t-elif="o.payment_state == 'in_payment'"><strong style="color: #1565c0;">IN PAYMENT</strong></t>
                        <t t-else=""><strong><span t-field="o.payment_state"/></strong></t>
                    </td>
                </tr>
                <tr t-if="o.patient_id">
                    <td>Patient:</td>
                    <td><span t-field="o.patient_id.name"/></td>
                </tr>
                <tr t-if="o.doctor_id">
                    <td>Doctor:</td>
                    <td><span t-field="o.doctor_id.name"/></td>
                </tr>
                <tr t-if="o.appointment_id">
                    <td>Appt Ref:</td>
                    <td><span t-field="o.appointment_id.name"/></td>
                </tr>
            </table>

            <div style="border-top: 1px solid #000; margin-bottom: 2px;"></div>

            <table style="font-size: 7px; margin-bottom: 2px; table-layout: fixed;">
                <colgroup>
                    <col style="width: 38mm;"/>
                    <col style="width: 15mm;"/>
                    <col style="width: 21mm;"/>
                </colgroup>
                <thead>
                    <tr style="font-weight: bold;">
                        <td>Item</td>
                        <td style="text-align: right;">Qty</td>
                        <td style="text-align: right;">Amount</td>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="fmt['lines']" t-as="line">
                        <tr>
                            <td style="word-break: break-all; padding-right: 2px;">
                                <span t-esc="line['name']"/>
                            </td>
                            <td style="text-align: right; white-space: nowrap;">
                                <span t-esc="line['quantity']"/>
                            </td>
                            <td style="text-align: right; white-space: nowrap;">
                                <span t-esc="line['amount']"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div style="border-top: 1px solid #000; margin-bottom: 2px;"></div>

            <table style="font-size: 7px; table-layout: fixed;">
                <colgroup>
                    <col style="width: 38mm;"/>
                    <col style="width: 36mm;"/>
                </colgroup>
                <tr t-if="o.amount_untaxed != o.amount_total">
                    <td>Subtotal</td>
                    <td style="text-align: right;">
                        <span t-esc="fmt['subtotal']"/>
                    </td>
                </tr>
                <tr t-if="o.amount_tax">
                    <td>Tax</td>
                    <td style="text-align: right;">
                        <span t-esc="fmt['tax']"/>
                    </td>
                </tr>
                <tr style="font-weight: bold; font-size: 9px;">
                    <td>Total</td>
                    <td style="text-align: right;">
                        <span t-esc="fmt['total']"/>
                    </td>
                </tr>
            </table>

            <div t-if="o.state == 'posted' and o.payment_state != 'paid'" style="font-size: 7px; margin-top: 3px; text-align: center;">
                <strong>Amount Due: </strong>
                <span t-esc="fmt['residual']"/>
            </div>

            <div t-if="o.invoice_payment_term_id" style="font-size: 6px; margin-top: 3px; text-align: center;">
                <span t-field="o.invoice_payment_term_id.name"/>
            </div>

            <div style="border-top: 1px dashed #000; margin-top: 4px; padding-top: 3px; text-align: center; font-size: 6px;">
                <span t-field="o.company_id.name"/>
                <div t-if="o.company_id.vat">VAT: <span t-field="o.company_id.vat"/></div>
                <div>Thank you for your visit!</div>
            </div>
        </div>
    </template>

    <record id="report_clinic_receipt" model="ir.actions.report">
        <field name="name">Receipt</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">clinic_management_system.receipt_invoice</field>
        <field name="report_file">clinic_management_system.receipt_invoice</field>
        <field name="print_report_name">(object.name or '').replace('/', '_') + '_receipt'</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_receipt"/>
    </record>
</odoo>
