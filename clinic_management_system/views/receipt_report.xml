<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_receipt" model="report.paperformat">
        <field name="name">Receipt (80mm)</field>
        <field name="format">custom</field>
        <field name="page_width">80</field>
        <field name="page_height">297</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line">False</field>
        <field name="header_spacing">0</field>
        <field name="dpi">203</field>
    </record>

    <template id="receipt_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang or o.company_id.partner_id.lang"/>
                <t t-call="clinic_management_system.receipt_invoice_document" t-lang="lang"/>
            </t>
        </t>
    </template>

    <template id="receipt_invoice_document">
        <div class="receipt" style="font-family: 'Courier New', monospace; font-size: 10px; max-width: 74mm; margin: 0 auto;">
            <div style="text-align: center; margin-bottom: 8px;">
                <h2 style="margin: 0; font-size: 14px; font-weight: bold;">
                    <span t-field="o.company_id.name"/>
                </h2>
                <div t-if="o.company_id.phone" style="font-size: 9px;">
                    Tel: <span t-field="o.company_id.phone"/>
                </div>
                <div t-if="o.company_id.email" style="font-size: 9px;">
                    <span t-field="o.company_id.email"/>
                </div>
                <div t-if="o.company_id.street" style="font-size: 9px;">
                    <span t-field="o.company_id.street"/>
                </div>
            </div>

            <div style="text-align: center; border-top: 1px dashed #000; border-bottom: 1px dashed #000; padding: 4px 0; margin-bottom: 8px;">
                <strong style="font-size: 12px;">RECEIPT</strong>
            </div>

            <table style="width: 100%; font-size: 9px; margin-bottom: 6px;">
                <tr>
                    <td style="width: 35%;">Receipt No:</td>
                    <td><strong><span t-field="o.name"/></strong></td>
                </tr>
                <tr>
                    <td>Date:</td>
                    <td><span t-field="o.invoice_date"/></td>
                </tr>
                <tr t-if="o.state == 'posted'">
                    <td>Status:</td>
                    <td>
                        <t t-if="o.payment_state == 'paid'">
                            <strong style="color: #2e7d32;">PAID</strong>
                        </t>
                        <t t-elif="o.payment_state == 'partial'">
                            <strong style="color: #e65100;">PARTIAL</strong>
                        </t>
                        <t t-elif="o.payment_state == 'not_paid'">
                            <strong style="color: #c62828;">UNPAID</strong>
                        </t>
                        <t t-elif="o.payment_state == 'in_payment'">
                            <strong style="color: #1565c0;">IN PAYMENT</strong>
                        </t>
                        <t t-else="">
                            <strong><span t-field="o.payment_state"/></strong>
                        </t>
                    </td>
                </tr>
                <tr t-if="o.patient_id">
                    <td>Patient:</td>
                    <td><span t-field="o.patient_id.name"/></td>
                </tr>
                <tr t-if="o.doctor_id">
                    <td>Doctor:</td>
                    <td><span t-field="o.doctor_id.name"/></td>
                </tr>
                <tr t-if="o.appointment_id">
                    <td>Appt Ref:</td>
                    <td><span t-field="o.appointment_id.name"/></td>
                </tr>
            </table>

            <div style="border-top: 1px solid #000; margin-bottom: 4px;"></div>

            <table style="width: 100%; font-size: 9px; margin-bottom: 4px;">
                <thead>
                    <tr style="font-weight: bold;">
                        <td style="width: 60%;">Description</td>
                        <td style="width: 20%; text-align: right;">Qty</td>
                        <td style="width: 20%; text-align: right;">Amount</td>
                    </tr>
                </thead>
                <tbody>
                    <tr style="border-top: 1px dotted #999;">
                        <td colspan="3"></td>
                    </tr>
                    <t t-foreach="o.invoice_line_ids" t-as="line">
                        <tr>
                            <td><span t-field="line.name"/></td>
                            <td style="text-align: right;"><span t-field="line.quantity"/></td>
                            <td style="text-align: right;">
                                <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div style="border-top: 1px solid #000; margin-bottom: 4px;"></div>

            <table style="width: 100%; font-size: 9px;">
                <tr t-if="o.amount_untaxed != o.amount_total">
                    <td style="width: 60%;">Subtotal</td>
                    <td style="text-align: right;">
                        <span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                    </td>
                </tr>
                <tr t-if="o.amount_tax">
                    <td>Tax</td>
                    <td style="text-align: right;">
                        <span t-field="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                    </td>
                </tr>
                <tr style="font-weight: bold; font-size: 11px;">
                    <td>Total</td>
                    <td style="text-align: right;">
                        <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                    </td>
                </tr>
            </table>

            <div t-if="o.invoice_payment_term_id" style="font-size: 8px; margin-top: 6px; text-align: center;">
                <span t-field="o.invoice_payment_term_id.name"/>
            </div>

            <div t-if="o.state == 'posted' and o.payment_state != 'paid'" style="font-size: 9px; margin-top: 4px; text-align: center;">
                <strong>Amount Due: </strong>
                <span t-field="o.amount_residual" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
            </div>

            <div style="border-top: 1px dashed #000; margin: 8px 0 4px; padding-top: 6px; text-align: center; font-size: 8px;">
                <span t-field="o.company_id.name"/>
                <div t-if="o.company_id.vat">VAT: <span t-field="o.company_id.vat"/></div>
                <div>Thank you for your visit!</div>
            </div>
        </div>
    </template>

    <record id="report_clinic_receipt" model="ir.actions.report">
        <field name="name">Receipt</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">clinic_management_system.receipt_invoice</field>
        <field name="report_file">clinic_management_system.receipt_invoice</field>
        <field name="print_report_name">(object.name or '').replace('/', '_') + '_receipt'</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_receipt"/>
    </record>
</odoo>
