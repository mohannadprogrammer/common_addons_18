<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Appointment Kanban View -->
    <record id="view_clinic_appointment_kanban" model="ir.ui.view">
        <field name="name">clinic.appointment.kanban</field>
        <field name="model">clinic.appointment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    class="o_kanban_small_column"
                    quick_create="false">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="shift_id"/>
                <field name="appointment_date"/>
                <field name="visit_fee"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="color"/>
                <field name="kanban_state"/>
                <field name="invoice_id"/>
                <progressbar field="kanban_state"
                             colors='{"normal": "200", "done": "success", "blocked": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_color_#{record.color.raw_value} oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="patient_id"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_top_right">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <i class="fa fa-user-md me-1"/>
                                        <field name="doctor_id"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-calendar me-1"/>
                                        <field name="appointment_date" widget="datetime"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-money me-1"/>
                                        <field name="visit_fee" widget="monetary"/>
                                    </div>
                                    <div t-if="record.invoice_id.raw_value">
                                        <span class="badge bg-success">
                                            <i class="fa fa-file-text-o me-1"/>Invoiced
                                        </span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="name" class="text-muted small"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="kanban_state" widget="kanban_state_selection"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Appointment Form View -->
    <record id="view_clinic_appointment_form" model="ir.ui.view">
        <field name="name">clinic.appointment.form</field>
        <field name="model">clinic.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button name="action_waiting" string="Check In" type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_start" string="Start Consultation" type="object"
                            class="oe_highlight"
                            invisible="state not in ('draft', 'waiting')"/>
                    <button name="action_done" string="Complete" type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object"
                            class="oe_highlight"
                            invisible="state != 'done' or invoice_id != False"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset" string="Reset" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,waiting,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="not invoice_id">
                            <span>Invoice</span>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Cancelled"
                            bg_color="bg-danger"
                            invisible="state != 'cancelled'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Appointment Details">
                            <field name="patient_id" readonly="state in ('in_progress', 'done')"/>
                            <field name="doctor_id" readonly="state in ('in_progress', 'done')"/>
                            <field name="product_id" readonly="state in ('in_progress', 'done')"/>
                            <field name="shift_id" readonly="state in ('in_progress', 'done')"/>
                            <field name="appointment_date" readonly="state in ('in_progress', 'done')"/>
                            <field name="priority" widget="priority" readonly="state in ('in_progress', 'done')"/>
                        </group>
                        <group string="Billing">
                            <field name="visit_fee" readonly="state in ('in_progress', 'done')"/>
                            <field name="currency_id" readonly="state in ('in_progress', 'done')"/>
                            <field name="invoice_id" readonly="1"/>
                            <field name="invoice_state" readonly="1"
                                   invisible="not invoice_id"/>
                        </group>
                    </group>
                    <group string="Notes / Diagnosis">
                        <field name="notes" nolabel="1" placeholder="Diagnosis, treatment notes..."/>
                    </group>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Appointment List View -->
    <record id="view_clinic_appointment_list" model="ir.ui.view">
        <field name="name">clinic.appointment.list</field>
        <field name="model">clinic.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'in_progress'"
                  decoration-muted="state == 'cancelled'">
                <field name="priority" widget="priority" optional="show"/>
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="shift_id"/>
                <field name="appointment_date"/>
                <field name="visit_fee" widget="monetary"/>
                <field name="invoice_state" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'in_progress'"
                       decoration-info="state == 'waiting'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Appointment Search View -->
    <record id="view_clinic_appointment_search" model="ir.ui.view">
        <field name="name">clinic.appointment.search</field>
        <field name="model">clinic.appointment</field>
        <field name="arch" type="xml">
            <search string="Appointments">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="shift_id"/>
                <filter string="Scheduled" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Waiting" name="waiting" domain="[('state', '=', 'waiting')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Not Invoiced" name="not_invoiced"
                        domain="[('state', '=', 'done'), ('invoice_id', '=', False)]"/>
                <separator/>
                <filter string="Today" name="today"
                        date="appointment_date"/>
                <group expand="0" string="Group By">
                    <filter string="Doctor" name="group_doctor" context="{'group_by': 'doctor_id'}"/>
                    <filter string="Shift" name="group_shift" context="{'group_by': 'shift_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'appointment_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Appointment Action (All) -->
    <record id="action_clinic_appointment_all" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">clinic.appointment</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_clinic_appointment_search"/>

    </record>
</odoo>