<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_shift_form" model="ir.ui.view">
        <field name="name">clinic.shift.form</field>
        <field name="model">clinic.shift</field>
        <field name="arch" type="xml">
            <form string="Shift">
                <header>
                    <button name="action_open" string="Open Shift" type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_close" string="Close Shift" type="object"
                            class="oe_highlight"
                            invisible="state != 'open'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                             invisible="state != 'open'"/>
                    <button name="action_reopen" string="Reopen Shift" type="object"
                             invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_customer_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <div class="o_stat_info">
                                <field name="customer_invoice_count" widget="statinfo"/>
                                
                            </div>
                        </button>
                        <button name="action_view_doctor_bills"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-money">
                            <div class="o_stat_info">
                                <field name="doctor_bill_count" widget="statinfo"/>
                                
                            </div>
                        </button>
                        
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Shift Details">
                            <field name="shift_type" readonly="state == 'closed'"/>
                            <field name="date" readonly="state == 'closed'"/>
                            <field name="start_time" readonly="state == 'closed'"/>
                            <field name="end_time" readonly="state == 'closed'"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state == 'closed'"/>
                        </group>
                        <group string="Team">
                            <field name="doctor_ids" widget="many2many_tags" readonly="state in ('open', 'closed')"/>
                        </group>
                    </group>
                    <group string="Financial Summary">
                        <group>
                            <field name="total_revenue" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_doctor_billing" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Appointments">
                            <field name="appointment_ids" readonly="state == 'closed'">
                                <list string="Appointments">
                                    <field name="name"/>
                                    <field name="patient_id"/>
                                    <field name="doctor_id"/>
                                    <field name="appointment_date"/>
                                    <field name="visit_fee"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_shift_list" model="ir.ui.view">
        <field name="name">clinic.shift.list</field>
        <field name="model">clinic.shift</field>
        <field name="arch" type="xml">
            <list string="Shifts"
                  decoration-success="state == 'closed'"
                  decoration-warning="state == 'open'">
                <field name="name"/>
                <field name="shift_type"/>
                <field name="date"/>
                <field name="doctor_ids" widget="many2many_tags"/>
                <field name="appointment_count"/>
                <field name="total_revenue"/>
                <field name="total_doctor_billing"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'closed'"
                       decoration-warning="state == 'open'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="view_clinic_shift_search" model="ir.ui.view">
        <field name="name">clinic.shift.search</field>
        <field name="model">clinic.shift</field>
        <field name="arch" type="xml">
            <search string="Shifts">
                <field name="name"/>
                <field name="doctor_ids"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Open" name="open" domain="[('state', '=', 'open')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <filter string="Day Shift" name="day" domain="[('shift_type', '=', 'day')]"/>
                <filter string="Night Shift" name="night" domain="[('shift_type', '=', 'night')]"/>
                <group expand="0" string="Group By">
                    <filter string="Shift Type" name="group_type" context="{'group_by': 'shift_type'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_clinic_shift" model="ir.actions.act_window">
        <field name="name">Shifts</field>
        <field name="res_model">clinic.shift</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clinic_shift_search"/>
    </record>
</odoo>
