<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clinic_doctor_form" model="ir.ui.view">
        <field name="name">clinic.doctor.form</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_clinic_appointment_all)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-calendar-check-o"
                                 context="{'search_default_doctor_id': id}">
                            <div class="o_stat_info">
                                <field name="appointment_count" widget="statinfo"/>
                                <span>Appointments</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="specialization"/>
                            <field name="product_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Billing Configuration">
                            <field name="billing_type"/>
                            <field name="billing_percentage"
                                   invisible="billing_type != 'percentage'"
                                   required="billing_type == 'percentage'"/>
                            <field name="billing_fixed_amount"
                                   invisible="billing_type != 'fixed'"
                                   required="billing_type == 'fixed'"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clinic_doctor_list" model="ir.ui.view">
        <field name="name">clinic.doctor.list</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <list string="Doctors" decoration-muted="not active">
                <field name="name"/>
                <field name="specialization"/>
                <field name="billing_type"/>
                <field name="billing_percentage"
                       invisible="billing_type != 'percentage'"/>
                <field name="billing_fixed_amount"
                       invisible="billing_type != 'fixed'"/>
                <field name="appointment_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_clinic_doctor_search" model="ir.ui.view">
        <field name="name">clinic.doctor.search</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <search string="Doctors">
                <field name="name"/>
                <field name="specialization"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_clinic_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">clinic.doctor</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clinic_doctor_search"/>
    </record>
</odoo>
